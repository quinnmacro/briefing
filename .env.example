# Briefing — Environment Variables
# Copy to .env and fill in your keys. .env is gitignored.

# ── Tavily AI Search (news/data retrieval) ──────────────────────
# Get key: https://tavily.com/ — free tier included
TAVILY_API_KEY=

# ── Bloomberg Terminal (via xbbg) ────────────────────────────────
# No key needed — requires Bloomberg Terminal running locally
# xbbg connects via BLPAPI automatically

# ── OpenEcon MCP (optional) ──────────────────────────────────────
# OPENECON_API_KEY=

# ── FRED API (optional, free macro data) ─────────────────────────
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=